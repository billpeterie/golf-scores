{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "build-tests",
			"command": "xcodebuild",
			"args": [
				"-project",
				"GolfScores.xcodeproj",
				"-scheme",
				"GolfScores",
				"-destination",
				"platform=iOS Simulator,name=iPhone 14",
				"test"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent"
			}
		}
	]
}